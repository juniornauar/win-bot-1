    clearInterval(autoInterval);
    clearInterval(countdownTimer);
    document.getElementById('countdown').textContent = '5:00';
    document.getElementById('progress-fill').style.width = '0%';
  }
}

function startCountdown() {
  clearInterval(countdownTimer);
  countdownSec = 300;
  countdownTimer = setInterval(()=>{
    countdownSec--;
    const m = Math.floor(countdownSec/60);
    const s = countdownSec % 60;
    document.getElementById('countdown').textContent = m+':'+(s<10?'0'+s:s);
    document.getElementById('progress-fill').style.width = ((300-countdownSec)/300*100)+'%';
    if(countdownSec <= 0) clearInterval(countdownTimer);
  }, 1000);
}

