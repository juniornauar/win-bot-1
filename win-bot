// ── Notification ───────────────────────────────────────
function showNotif(title, body, type='buy') {
  const area = document.getElementById('notif-area');
  const n = document.createElement('div');
  n.className = 'notif ' + (type==='sell'?'sell':type==='wait'?'wait':'');
  n.innerHTML = `<div class="notif-title">${title}</div><div style="color:var(--muted);font-size:.71rem;margin-top:2px">${body}</div>`;
  area.appendChild(n);
  setTimeout(()=>n.remove(), 5300);
  // Sound ping
  try {
    const ac = new (window.AudioContext||window.webkitAudioContext)();
    const osc = ac.createOscillator();
    const gain = ac.createGain();
    osc.connect(gain); gain.connect(ac.destination);
    osc.frequency.value = type==='sell' ? 440 : 660;
    gain.gain.setValueAtTime(0.08, ac.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 0.4);
    osc.start(); osc.stop(ac.currentTime + 0.4);
  } catch(e) {}
}

