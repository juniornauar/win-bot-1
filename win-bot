// ── Mini Chart ─────────────────────────────────────────
function drawChart(prices) {
  const canvas = document.getElementById('priceChart');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const W = canvas.parentElement.clientWidth - 36;
  const H = 120;
  canvas.width = W * dpr; canvas.height = H * dpr;
  canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
  ctx.scale(dpr, dpr);
  ctx.clearRect(0,0,W,H);

  const min = Math.min(...prices) - 200;
  const max = Math.max(...prices) + 200;
  const mm20 = prices.reduce((a,b) => a+b, 0) / prices.length;
  const res = 178800;

  const xOf = i => (i / (prices.length - 1)) * (W - 20) + 10;
  const yOf = v => H - ((v - min) / (max - min)) * (H - 20) - 10;

  // grid
  ctx.strokeStyle = '#0d2030'; ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = (H / 4) * i;
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }

  // resistance line
  const yr = yOf(res);
  ctx.strokeStyle = '#ff3a5c55'; ctx.lineWidth = 1; ctx.setLineDash([4,4]);
  ctx.beginPath(); ctx.moveTo(0, yr); ctx.lineTo(W, yr); ctx.stroke();
  ctx.setLineDash([]);

  // MM20 line
  const ym = yOf(mm20);
  ctx.strokeStyle = '#f5c51888'; ctx.lineWidth = 1.5; ctx.setLineDash([3,3]);
  ctx.beginPath(); ctx.moveTo(0, ym); ctx.lineTo(W, ym); ctx.stroke();
  ctx.setLineDash([]);

  // area fill
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, '#00c89622'); grad.addColorStop(1, 'transparent');
  ctx.fillStyle = grad;
  ctx.beginPath();
  ctx.moveTo(xOf(0), yOf(prices[0]));
  prices.forEach((p,i) => ctx.lineTo(xOf(i), yOf(p)));
  ctx.lineTo(xOf(prices.length-1), H); ctx.lineTo(xOf(0), H); ctx.closePath();
  ctx.fill();

  // price line
  ctx.strokeStyle = '#00c896'; ctx.lineWidth = 2; ctx.lineJoin = 'round';
  ctx.beginPath();
  prices.forEach((p,i) => i===0 ? ctx.moveTo(xOf(i),yOf(p)) : ctx.lineTo(xOf(i),yOf(p)));
  ctx.stroke();

  // last dot
  const lx = xOf(prices.length-1), ly = yOf(prices[prices.length-1]);
  ctx.fillStyle = '#00c896'; ctx.shadowColor = '#00c896'; ctx.shadowBlur = 8;
  ctx.beginPath(); ctx.arc(lx, ly, 4, 0, Math.PI*2); ctx.fill();
  ctx.shadowBlur = 0;

  // label last price
  ctx.fillStyle = '#00c896'; ctx.font = '600 10px Share Tech Mono, monospace';
  ctx.fillText(prices[prices.length-1].toLocaleString('pt-BR'), lx - 38, ly - 8);
}

