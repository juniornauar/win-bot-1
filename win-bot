      <div class="nb">${n.corpo} <strong style="color:${impactColor}">Impacto: ${n.impacto}</strong></div>`;
    el.addEventListener('click',()=>el.classList.toggle('open'));
    list.appendChild(el);
  });
  document.getElementById('news-stamp').textContent = `— atualizado ${hora}`;
}

function addHistoryItem(dir, entrada, now) {
  const list = document.getElementById('hist-list');
  const open = list.querySelector('.hist-item.open');
  if(open) {
    open.querySelector('.h-dir').textContent = (dir==='VENDA'?'▼ VENDA':dir==='COMPRA'?'▲ COMPRA':'— AGUARDAR');
    open.querySelector('.h-dir').className = 'h-dir '+(dir==='VENDA'?'sell':dir==='COMPRA'?'buy':'');
  }
  // add new open item
  const item = document.createElement('div');
  item.className = 'hist-item open';
  const t = now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
  item.innerHTML = `
    <div class="h-time">${t}</div>
    <div class="h-dir ${dir==='VENDA'?'sell':'buy'}">${dir==='VENDA'?'▼ VENDA':'▲ COMPRA'}</div>
    <div style="font-size:.73rem;color:var(--muted)">Entrada ${entrada} — em aberto</div>
    <div class="h-pts open">Em curso</div>
    <div class="h-status open">● Aberto</div>`;
  list.appendChild(item);
}

